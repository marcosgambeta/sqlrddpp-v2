################################################
# Makefile for xHarbour and Clang 32-bit/64-bit
################################################
# Usage:
# mkdir lib
# mkdir obj
# set HB_INC_DIR=<path to xHarbour include dir>
# mingw32-make -f Makefile.clang
################################################

INC_DIR = include
LIB_DIR = lib
OBJ_DIR = obj
SRC_DIR = source
OBJ_EXT = .o
LIB_EXT = .a
LIB_PRE = lib

HB = harbour

HBFLAGS = \
	-n \
	-w2 \
	-es2 \
	-I$(INC_DIR) \
	-I$(SRC_DIR) \
	-I$(HB_INC_DIR)

CC = clang

CFLAGS = \
	-Wall \
	-O2 \
	-I$(INC_DIR) \
	-I$(INC_DIR)/firebird \
	-I$(INC_DIR)/mysql \
	-I$(INC_DIR)/oci \
	-I$(INC_DIR)/pgsql \
	-I$(SRC_DIR) \
	-I$(SRC_DIR)/parser \
	-I$(SRC_DIR)/oracle \
	-I$(HB_INC_DIR) \
	-D_HB_API_INTERNAL_ \
	-Wno-missing-prototype-for-cc \
	-Wno-unused-function

LIB_NAME = $(LIB_DIR)/$(LIB_PRE)sqlrddpp-v2$(LIB_EXT)
LIB_NAME_FIREBIRD = $(LIB_DIR)/$(LIB_PRE)sqlrddpp-v2-firebird$(LIB_EXT)
LIB_NAME_MYSQL = $(LIB_DIR)/$(LIB_PRE)sqlrddpp-v2-mysql$(LIB_EXT)
LIB_NAME_ORACLE = $(LIB_DIR)/$(LIB_PRE)sqlrddpp-v2-oracle$(LIB_EXT)
LIB_NAME_POSTGRESQL = $(LIB_DIR)/$(LIB_PRE)sqlrddpp-v2-postgresql$(LIB_EXT)

all: $(LIB_NAME) $(LIB_NAME_FIREBIRD) $(LIB_NAME_MYSQL) $(LIB_NAME_ORACLE) $(LIB_NAME_POSTGRESQL)

###########
# .o -> .a
###########

$(LIB_NAME): \
	$(OBJ_DIR)/exprobjs$(OBJ_EXT) \
	$(OBJ_DIR)/exprparser$(OBJ_EXT) \
	$(OBJ_DIR)/exprrelation$(OBJ_EXT) \
	$(OBJ_DIR)/exprsimpl$(OBJ_EXT) \
	$(OBJ_DIR)/exprtransl$(OBJ_EXT) \
	$(OBJ_DIR)/exprudf$(OBJ_EXT) \
	$(OBJ_DIR)/sqlconnection$(OBJ_EXT) \
	$(OBJ_DIR)/sqlgen1$(OBJ_EXT) \
	$(OBJ_DIR)/sqlrdd0$(OBJ_EXT) \
	$(OBJ_DIR)/sqlrdd2$(OBJ_EXT) \
	$(OBJ_DIR)/utils$(OBJ_EXT) \
	$(OBJ_DIR)/utilslang$(OBJ_EXT) \
	$(OBJ_DIR)/sr_firebird$(OBJ_EXT) \
	$(OBJ_DIR)/sr_firebird3$(OBJ_EXT) \
	$(OBJ_DIR)/sr_firebird4$(OBJ_EXT) \
	$(OBJ_DIR)/sr_firebird5$(OBJ_EXT) \
	$(OBJ_DIR)/sr_mariadb$(OBJ_EXT) \
	$(OBJ_DIR)/sr_mysql$(OBJ_EXT) \
	$(OBJ_DIR)/sr_odbc$(OBJ_EXT) \
	$(OBJ_DIR)/sr_oracle$(OBJ_EXT) \
	$(OBJ_DIR)/sr_oracle2$(OBJ_EXT) \
	$(OBJ_DIR)/sr_pgs$(OBJ_EXT) \
	$(OBJ_DIR)/sqlact$(OBJ_EXT) \
	$(OBJ_DIR)/sqlex1$(OBJ_EXT) \
	$(OBJ_DIR)/sqlex2$(OBJ_EXT) \
	$(OBJ_DIR)/sqlex3$(OBJ_EXT) \
	$(OBJ_DIR)/sqllex$(OBJ_EXT) \
	$(OBJ_DIR)/sqlrdd1$(OBJ_EXT) \
	$(OBJ_DIR)/tracelog$(OBJ_EXT) \
	$(OBJ_DIR)/xthrow$(OBJ_EXT) \
	$(OBJ_DIR)/sqly$(OBJ_EXT) \
	$(OBJ_DIR)/sqlora$(OBJ_EXT)
	ar rc $@ $^
	ranlib $@

