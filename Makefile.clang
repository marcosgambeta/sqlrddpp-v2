#####################
# .prg -> .cpp -> .o
#####################

$(OBJ_DIR)/exprobjs.cpp : $(SRC_DIR)/exprobjs.prg
	$(HB) $(HBFLAGS) $< -o$@
$(OBJ_DIR)/exprobjs$(OBJ_EXT) : $(OBJ_DIR)/exprobjs.cpp
	$(CC) $(CFLAGS) -c $< -o $@

$(OBJ_DIR)/exprparser.cpp : $(SRC_DIR)/exprparser.prg
	$(HB) $(HBFLAGS) $< -o$@
$(OBJ_DIR)/exprparser$(OBJ_EXT) : $(OBJ_DIR)/exprparser.cpp
